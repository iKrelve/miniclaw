{
  "name": "miniclaw",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cd sidecar && bun install --frozen-lockfile 2>/dev/null; cd .. && bun run build:sidecar && tauri dev",
    "dev:web": "vite",
    "dev:sidecar": "cd sidecar && bun run dev",
    "build": "cd sidecar && bun install --frozen-lockfile 2>/dev/null; cd .. && bun run build:sidecar && tauri build",
    "build:frontend": "tsc && vite build",
    "build:sidecar": "cd sidecar && bun run build",
    "preview": "vite preview",
    "tauri": "tauri",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src/ shared/",
    "lint:fix": "oxlint src/ shared/ --fix",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "test": "cd sidecar && bun test",
    "deadcode": "knip --production --no-progress",
    "check": "bun run format:check && bun run lint && bun run typecheck",
    "postinstall": "cd sidecar && bun install",
    "prepare": "lefthook install",
    "setup": "bun install && bun run build:sidecar"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-global-shortcut": "^2.3.1",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-store": "^2.4.2",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "@tauri-apps/plugin-window-state": "^2.4.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "motion": "^12.38.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "shiki": "^4.0.2",
    "sonner": "^2.0.7",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.5.0",
    "use-stick-to-bottom": "^1.1.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "knip": "^5.86.0",
    "lefthook": "^1.11.13",
    "oxfmt": "0.41.0",
    "oxlint": "^1.56.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "vite": "^8.0.1"
  }
}
