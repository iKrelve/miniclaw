#!/bin/sh
# MiniClaw Desk CLI — communicates with the MiniClaw sidecar HTTP server.
# Auto-generated by MiniClaw. Do not edit.
#
# Usage:
#   miniclaw-desk browser-action '<json>'
#   miniclaw-desk browser-action status
#   miniclaw-desk status
#
# The sidecar port is discovered from ~/.miniclaw/sidecar.port

set -e

# ── Port discovery ──────────────────────────────────────────────────────

PORT_FILE="$HOME/.miniclaw/sidecar.port"

get_port() {
  if [ ! -f "$PORT_FILE" ]; then
    echo "Error: MiniClaw is not running (no port file at $PORT_FILE)" >&2
    exit 1
  fi
  cat "$PORT_FILE"
}

BASE_URL="http://127.0.0.1:$(get_port)"

# ── HTTP helper ─────────────────────────────────────────────────────────

http_get() {
  curl -s --fail --max-time 30 "$BASE_URL$1" 2>/dev/null
}

http_post() {
  curl -s --fail --max-time 120 -X POST \
    -H "Content-Type: application/json" \
    -d "$2" \
    "$BASE_URL$1" 2>/dev/null
}

# ── Commands ────────────────────────────────────────────────────────────

cmd_status() {
  http_get "/browser/status"
}

cmd_browser_action() {
  if [ -z "$1" ]; then
    echo "Usage: miniclaw-desk browser-action '<json>' | status" >&2
    exit 1
  fi

  if [ "$1" = "status" ]; then
    cmd_status
    return
  fi

  # Forward JSON command to sidecar
  http_post "/browser/action" "$1"
}

cmd_help() {
  cat <<'EOF'
MiniClaw Desk CLI

Usage:
  miniclaw-desk browser-action '<json>'    Execute a browser command
  miniclaw-desk browser-action status      Get browser status
  miniclaw-desk status                     Get sidecar health status
  miniclaw-desk help                       Show this help

Browser Action JSON format:
  {"action":"open","args":["https://example.com"]}
  {"action":"snapshot","args":["-i"]}
  {"action":"click","args":["@e1"]}
  {"action":"fill","args":["@e2","text"]}
  {"action":"screenshot"}

See ~/.claude/skills/miniclaw-browser/SKILL.md for full command reference.
EOF
}

# ── Main ────────────────────────────────────────────────────────────────

case "${1:-help}" in
  browser-action)
    shift
    cmd_browser_action "$@"
    ;;
  status)
    http_get "/health"
    ;;
  help|--help|-h)
    cmd_help
    ;;
  *)
    echo "Unknown command: $1" >&2
    echo "Run 'miniclaw-desk help' for usage." >&2
    exit 1
    ;;
esac